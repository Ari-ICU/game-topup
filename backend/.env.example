PORT=5001
NODE_ENV=development

# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
DATABASE_URL="mongodb://localhost:27017/topup?replicaSet=rs0"

# ─────────────────────────────────────────────
# ADMIN AUTH — REQUIRED, change before production
# ─────────────────────────────────────────────
# Use a strong passcode (min 12 chars, mix letters/numbers/symbols)
ADMIN_PASSCODE="YourStrongPasscode123!"

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-64-byte-hex-random-string-here"
JWT_EXPIRES_IN="1d"

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"

# ─────────────────────────────────────────────
# BAKONG / KHQR PAYMENT
# ─────────────────────────────────────────────
BAKONG_ACCOUNT_ID="your_account@bank"
BAKONG_API_TOKEN="your-bakong-api-token"

# Required in production: set to the webhook secret provided by Bakong
BAKONG_WEBHOOK_SECRET=""

# ─────────────────────────────────────────────
# PROVIDER API CREDENTIALS (leave blank for sandbox/mock mode)
# ─────────────────────────────────────────────
SMILEONE_EMAIL=""
SMILEONE_API_KEY=""
SMILEONE_API_URL="https://api.smileone.com/v1/order"

UNIPIN_SECRET=""
UNIPIN_API_URL="https://api.unipin.com/v1/topup"

TOPUPLIVE_MERCHANT_ID=""
TOPUPLIVE_API_KEY=""
TOPUPLIVE_API_URL="https://api.topuplive.com/v1/order"

# ─────────────────────────────────────────────
# TELEGRAM BOT INTEGRATION
# ─────────────────────────────────────────────
# API Token obtained from @BotFather
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
# Target Chat/Channel ID for transaction alerts (e.g. -100xxxxxxxxxx or chat ID)
TELEGRAM_CHAT_ID="your-telegram-chat-id"
# Comma-separated list of Telegram usernames authorized to execute admin commands
TELEGRAM_ADMIN_USERNAMES="admin_username1,admin_username2"
